<?xml version="1.0" encoding="utf-8"?>
<!--
  Pins the runtime so a future rebuild can't silently drift onto a .NET-Core-only
  API. myatg uses only the .NET Framework 4.x BCL + Win32 P/Invoke (x86_64).
  Ship this next to myatg.exe.
-->
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
</configuration>
